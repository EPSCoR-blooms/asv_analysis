catabot_deployments <- as.Date(c("2021-07-01", "2021-07-22", "2021-08-05", "2021-08-10", "2021-08-27", "2021-09-16")) #select date/times overlapping with Catabot deployments

buoy_cat <- buoy_spc %>%
  filter(as.Date(date) %in% catabot_deployments)

buoy_cat_final <- buoy_cat %>%
  filter(time >= "09:00" & time <= "14:00")

buoy_cat_final$time <- as.POSIXct(buoy_cat_final$time, format="%H:%M", tz="UTC") #calculate means for each date

buoy_cat_means <- buoy_cat_final %>%
  mutate(time_numeric = as.numeric(format(time, "%H")) * 60 + as.numeric(format(time, "%M")))

buoy_cat_means <- buoy_cat_means %>%
  group_by(date) %>%
  mutate(mean_value = mean(specificConductance_mScm_1m, na.rm = TRUE))

# Plot specific conductance by date

July_01 <- ggplot(buoy_cat_means %>%
                    filter(date == "2021-07-01"),  # Change for the specific date
                  aes(x = time_numeric, y = specificConductance_mScm_1m)) +
  geom_point(color = "#2B8DBE", alpha = 0.7, size = 1) + 
  geom_hline(aes(yintercept = mean_value), linetype = "solid", color = "grey", alpha = 0.8, size = .5) +  
  scale_x_continuous(
    breaks = c(10 * 60, 11 * 60, 12 * 60, 13 * 60),  # Set specific breaks for 10:00, 11:00, 12:00, 13:00 (in minutes)
    labels = function(x) format(as.POSIXct(x * 60, origin = "1970-01-01", tz = "UTC"), "%H:%M")  # Format labels as HH:MM
  ) +
  scale_y_continuous(
    name = "Specific Conductance (\U00B5S/cm)", 
    limits = c(98, 101.5) 
  ) +
  labs(
